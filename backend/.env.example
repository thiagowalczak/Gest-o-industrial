# ════════════════════════════════════════════════════════════
#   CONFIGURAÇÕES DO SISTEMA - GESTÃO INDUSTRIAL (SaaS)
#   Copie este arquivo para ".env" e ajuste os valores.
#   Não apague os # das linhas de comentário
# ════════════════════════════════════════════════════════════

# ── BANCO DE DADOS ────────────────────────────────────────────
# Em produção (Render, Railway, etc.) defina DATABASE_URL com a
# string de conexão do PostgreSQL fornecida pelo provedor.
# Exemplo: postgresql://usuario:senha@host:5432/nome_do_banco
# Se DATABASE_URL não for definida, o sistema usa um arquivo
# SQLite local (bom para testar no seu computador).
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Usado apenas quando DATABASE_URL não está definida (modo local)
LOCAL_DB_PATH=./gestao_local.db

# ── SEGURANÇA ────────────────────────────────────────────────
# Chave secreta para proteger os logins (tokens JWT)
# Troque por um texto longo, aleatório e secreto (mínimo 32 caracteres)
# Você pode gerar uma com: openssl rand -hex 32
SECRET_KEY=troque-por-uma-chave-segura-de-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ─────────────────────────────────────────────────────
# Domínios extras (além de localhost) que podem acessar a API,
# separados por vírgula. Ex: https://meusistema.onrender.com
CORS_ORIGINS=

# ── E-MAIL (recuperação de senha) ────────────────────────────
# Crie uma conta gratuita em https://resend.com, verifique um domínio
# (ou use o remetente de testes onboarding@resend.dev) e gere uma API key.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── INFORMAÇÕES DO SISTEMA ───────────────────────────────────
APP_NAME=Gestão Industrial
# URL pública do sistema, usada para montar o link de redefinição de senha
APP_URL=http://localhost:5173

# Porta usada pelo servidor (em produção o provedor define
# automaticamente a variável PORT)
PORT=8000
